{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Ressl",
  "description": "Hosted mock SaaS APIs for agents and evaluations.",
  "colors": {
    "primary": "#171717",
    "light": "#404040",
    "dark": "#FAFAFA"
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark"
  },
  "styling": {
    "codeblocks": "system"
  },
  "favicon": "/logo/icon-dark.png",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://simulation.ressl.ai"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["index", "quickstart"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Platform API",
            "pages": [
              "api-reference/authentication",
              "api-reference/list-providers",
              "api-reference/create-snapshot"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "baseUrl": "https://simulation.ressl.ai"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://simulation.ressl.ai"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ResslAI-Salesforce"
    }
  }
}
